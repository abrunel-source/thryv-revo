---
import { site } from '../data/site';
import { type Locale, routes } from '../i18n/config';
import { t } from '../i18n/ui';
interface Props { title?: string; text?: string; lang?: Locale }
const { lang = 'en', title, text } = Astro.props;
const dict = t(lang);
const heading = title ?? dict.cta.title;
const body = text ?? dict.cta.text;
---
<section class="cta-band">
  <div class="container inner">
    <div>
      <h2>{heading}</h2>
      <p>{body}</p>
    </div>
    <div class="cta-actions">
      <a href={routes(lang).contact} class="btn btn--light">{dict.common.bookCall}</a>
      <a href={site.phoneHref} class="btn btn--on-dark">{site.phoneDisplay}</a>
    </div>
  </div>
</section>

<style>
  .cta-band { background: var(--gradient); color: #fff; }
  .inner {
    display: flex; align-items: center; justify-content: space-between; gap: 2rem; flex-wrap: wrap;
    padding: clamp(2.5rem, 6vw, 4rem) 22px;
  }
  .cta-band h2 { color: #fff; margin-bottom: 0.4rem; }
  .cta-band p { color: #cfe6e4; max-width: 46ch; margin: 0; }
  .cta-actions { display: flex; gap: 0.8rem; flex-wrap: wrap; }
</style>
