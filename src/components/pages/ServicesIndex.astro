---
import PageHero from '../PageHero.astro';
import CtaBand from '../CtaBand.astro';
import Icon from '../Icon.astro';
import { currency } from '../../data/site';
import { type Locale, routes } from '../../i18n/config';
import { t } from '../../i18n/ui';
import { getServices, getPackages } from '../../i18n/content';

interface Props { lang?: Locale }
const { lang = 'en' } = Astro.props;
const d = t(lang).services;
const r = routes(lang);
const services = getServices(lang);
const packages = getPackages(lang);
---
<PageHero eyebrow={d.heroEyebrow} title={d.heroTitle} text={d.heroText} />

<section class="section">
  <div class="container">
    <div class="grid grid-3">
      {services.map((s) => (
        <a href={s.href} class="card service-card">
          <div class="icon-chip"><Icon name={s.icon} /></div>
          <span class="tagline">{s.tagline}</span>
          <h3>{s.title}</h3>
          <p class="muted">{s.summary}</p>
          <span class="learn">{t(lang).common.learnMore} <Icon name="arrow" class="ic" /></span>
        </a>
      ))}
    </div>
  </div>
</section>

<section class="section section--soft">
  <div class="container">
    <div class="section-head center">
      <span class="eyebrow">{d.pricingEyebrow}</span>
      <h2>{d.pricingTitle}</h2>
      <p class="lead">{d.pricingIntro}</p>
    </div>
    <div class="grid grid-3 mini-pricing">
      {packages.map((p) => (
        <div class={`card mini${p.best ? ' mini--best' : ''}`}>
          <h3>{p.name}</h3>
          <div class="price"><span>{currency}</span>{p.price.toLocaleString('en-ZA')}<small>/mo</small></div>
          <p class="muted">{p.blurb}</p>
          <a href={r.contact} class={`btn ${p.best ? 'btn--primary' : 'btn--ghost'}`}>{d.getStarted}</a>
        </div>
      ))}
    </div>
  </div>
</section>

<CtaBand lang={lang} />

<style>
  .service-card { display: flex; flex-direction: column; }
  .service-card h3 { color: var(--ink); margin-bottom: 0.4rem; }
  .tagline { font-family: var(--font-head); font-weight: 700; font-size: 0.78rem; letter-spacing: 0.06em; text-transform: uppercase; color: var(--teal-600); margin-bottom: 0.5rem; }
  .service-card .muted { flex: 1; font-size: 0.96rem; }
  .learn { display: inline-flex; align-items: center; gap: 0.4rem; color: var(--teal-700); font-family: var(--font-head); font-weight: 600; font-size: 0.92rem; margin-top: 1rem; }
  .ic { width: 18px; height: 18px; }
  .mini { text-align: center; }
  .mini--best { border-color: var(--teal-500); box-shadow: var(--shadow); }
  .mini .price { font-family: var(--font-head); font-weight: 800; font-size: 2rem; color: var(--ink); margin: 0.3rem 0 0.4rem; }
  .mini .price span { font-size: 1rem; vertical-align: super; }
  .mini .price small { font-size: 0.85rem; color: var(--slate); font-weight: 600; }
  .mini .btn { margin-top: 0.8rem; justify-content: center; width: 100%; }
</style>
