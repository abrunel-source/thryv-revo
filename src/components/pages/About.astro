---
import PageHero from '../PageHero.astro';
import CtaBand from '../CtaBand.astro';
import Icon from '../Icon.astro';
import { site } from '../../data/site';
import { type Locale } from '../../i18n/config';
import { t } from '../../i18n/ui';

interface Props { lang?: Locale }
const { lang = 'en' } = Astro.props;
const d = t(lang).about;
const valueIcons = ['spark', 'shield', 'compass', 'users'];
const roles = d.roles as Record<string, string>;
---
<PageHero eyebrow={d.heroEyebrow} title={d.heroTitle} text={d.heroText} />

<section class="section">
  <div class="container two-col">
    <div>
      <span class="eyebrow">{d.storyEyebrow}</span>
      <h2>{d.storyTitle}</h2>
      {d.story.map((p) => <p set:html={p} />)}
    </div>
    <aside class="mission-card">
      <h3>{d.missionTitle}</h3>
      <p set:html={d.missionText} />
      <div class="loc">
        <span><Icon name="pin" /> {site.locations.join(' & ')}</span>
        <span><Icon name="mail" /> {site.email}</span>
        <span><Icon name="phone" /> {site.phoneDisplay}</span>
      </div>
    </aside>
  </div>
</section>

<section class="section section--soft">
  <div class="container">
    <div class="section-head center"><span class="eyebrow">{d.valuesEyebrow}</span><h2>{d.valuesTitle}</h2></div>
    <div class="grid grid-4">
      {d.values.map((v, i) => (
        <div class="card value">
          <div class="icon-chip"><Icon name={valueIcons[i]} /></div>
          <h3>{v.t}</h3>
          <p class="muted">{v.d}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-head center"><span class="eyebrow">{d.teamEyebrow}</span><h2>{d.teamTitle}</h2></div>
    <div class="grid grid-2 team">
      {site.founders.map((f) => (
        <div class="card member">
          <div class="avatar">{f.name.split(' ').map((n) => n[0]).join('')}</div>
          <div>
            <h3>{f.name}</h3>
            <p class="muted">{roles[f.role] ?? f.role}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<CtaBand lang={lang} />

<style>
  .two-col { display: grid; grid-template-columns: 1.3fr 0.7fr; gap: 3rem; align-items: start; }
  .mission-card { background: var(--bg-mint); border-radius: var(--radius-lg); padding: 2rem; }
  .mission-card h3 { color: var(--teal-700); }
  .loc { display: grid; gap: 0.6rem; margin-top: 1.4rem; padding-top: 1.4rem; border-top: 1px solid var(--line-strong); font-size: 0.95rem; }
  .loc span { display: inline-flex; align-items: center; gap: 0.5rem; color: var(--ink-700); }
  .loc :global(svg) { width: 17px; height: 17px; color: var(--teal-600); }
  .value h3 { font-size: 1.12rem; }
  .team .member { display: flex; align-items: center; gap: 1.2rem; }
  .avatar { width: 64px; height: 64px; border-radius: 50%; background: var(--gradient-bright); color: #fff; display: grid; place-items: center; font-family: var(--font-head); font-weight: 800; font-size: 1.3rem; flex: none; }
  .member h3 { margin: 0; font-size: 1.2rem; }
  .member p { margin: 0.2rem 0 0; }
  @media (max-width: 820px) { .two-col { grid-template-columns: 1fr; } }
</style>
