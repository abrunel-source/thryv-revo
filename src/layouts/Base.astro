---
import '@fontsource-variable/plus-jakarta-sans';
import '@fontsource-variable/inter';
import jakartaFont from '@fontsource-variable/plus-jakarta-sans/files/plus-jakarta-sans-latin-wght-normal.woff2?url';
import interFont from '@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Analytics from '@vercel/analytics/astro';
import { site } from '../data/site';
import { type Locale, htmlLang, ogLocale } from '../i18n/config';
import { t } from '../i18n/ui';

interface Props {
  title?: string;
  fullTitle?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  jsonLd?: object | object[];
  lang?: Locale;
  alternates?: Partial<Record<Locale, string>>;
}

const {
  title,
  fullTitle: fullTitleProp,
  description = site.description,
  image = site.ogImage,
  noindex = false,
  jsonLd,
  lang = 'en',
  alternates = {},
} = Astro.props;

const dict = t(lang);
// hreflang alternates (root-relative paths in, absolute URLs out). x-default = en.
const altEntries = Object.entries(alternates) as [Locale, string][];

const fullTitle = fullTitleProp
  ? fullTitleProp
  : title
    ? `${title} | ${site.name}`
    : `${site.name} — ${site.tagline}`;
const canonical = new URL(Astro.url.pathname, site.url).href;
const ogImage = new URL(image, site.url).href;

const orgLd = {
  '@context': 'https://schema.org',
  '@type': 'AccountingService',
  '@id': `${site.url}/#organization`,
  name: site.legalName,
  alternateName: site.name,
  description: site.description,
  url: site.url,
  logo: new URL(site.logo, site.url).href,
  image: ogImage,
  email: site.email,
  telephone: site.phoneDisplay,
  priceRange: 'RR',
  currenciesAccepted: 'ZAR',
  knowsAbout: [
    'Accounting', 'Bookkeeping', 'Tax', 'VAT', 'Provisional tax', 'Payroll',
    'Audit', 'Independent review', 'Annual financial statements', 'Company secretary',
    'CIPC compliance', 'SARS compliance', 'IFRS for SMEs', 'Employer of Record',
  ],
  areaServed: [
    { '@type': 'City', name: 'Cape Town' },
    { '@type': 'City', name: 'Stellenbosch' },
    { '@type': 'Country', name: 'South Africa' },
  ],
  address: { '@type': 'PostalAddress', addressLocality: 'Cape Town', addressRegion: 'Western Cape', addressCountry: 'ZA' },
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
    opens: '08:00',
    closes: '17:00',
  },
  founder: site.founders.map((f) => ({ '@type': 'Person', name: f.name, jobTitle: f.role })),
  sameAs: [site.social.facebook, site.social.linkedin, site.social.twitter],
};

const blocks = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
---
<!doctype html>
<html lang={htmlLang[lang]}>
  <head>
    <Analytics />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {altEntries.map(([l, path]) => (
      <link rel="alternate" hreflang={htmlLang[l]} href={new URL(path, site.url).href} />
    ))}
    {alternates.en && <link rel="alternate" hreflang="x-default" href={new URL(alternates.en, site.url).href} />}
    {noindex
      ? <meta name="robots" content="noindex, nofollow" />
      : <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />}
    <meta name="theme-color" content="#0b7a75" />

    <!-- Preload primary fonts to avoid layout shift on swap -->
    <link rel="preload" href={jakartaFont} as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="preload" href={interFont} as="font" type="font/woff2" crossorigin="anonymous" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={ogLocale[lang]} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/png" href="/img/thryv-logo.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <script type="application/ld+json" set:html={JSON.stringify(orgLd)} />
    {blocks.map((b) => <script type="application/ld+json" set:html={JSON.stringify(b)} />)}
  </head>
  <body>
    <a href="#main" class="skip-link">{dict.common.skip}</a>
    <Header lang={lang} alternates={alternates} />
    <main id="main">
      <slot />
    </main>
    <Footer lang={lang} />
    <style>
      .skip-link {
        position: absolute; left: -999px; top: 0; z-index: 200;
        background: var(--teal-700); color: #fff; padding: 0.7rem 1rem; border-radius: 0 0 8px 0;
      }
      .skip-link:focus { left: 0; color: #fff; }
    </style>
  </body>
</html>
