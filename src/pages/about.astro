---
import Base from '../layouts/Base.astro';
import About from '../components/pages/About.astro';
import { site } from '../data/site';
import { routes } from '../i18n/config';
import { t } from '../i18n/ui';

const lang = 'en';
const meta = t(lang).meta;
const alternates = { en: routes('en').about, af: routes('af').about };
const aboutLd = [
  { '@context': 'https://schema.org', '@type': 'AboutPage', name: 'About Thryv', url: `${site.url}/about/`, about: { '@id': `${site.url}/#organization` } },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: site.url + '/' },
      { '@type': 'ListItem', position: 2, name: 'About', item: site.url + '/about/' },
    ],
  },
];
---
<Base lang={lang} alternates={alternates} title={meta.aboutTitle} description={meta.aboutDesc} jsonLd={aboutLd}>
  <About lang={lang} />
</Base>
