---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import CtaBand from '../components/CtaBand.astro';
import Icon from '../components/Icon.astro';
import { site } from '../data/site';

const values = [
  { icon: 'spark', t: 'Genuine partnership', d: "We act as a business partner, not just an accountant — invested in your growth." },
  { icon: 'shield', t: 'Excellence & integrity', d: 'Rigorous, compliant work you can trust, every single time.' },
  { icon: 'compass', t: 'Clarity & insight', d: 'Plain-language reporting and advice that helps you decide with confidence.' },
  { icon: 'users', t: 'Service-driven', d: 'We take the time to understand your unique needs and challenges.' },
];

const aboutLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'AboutPage',
    name: 'About Thryv',
    url: `${site.url}/about/`,
    about: { '@id': `${site.url}/#organization` },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: site.url + '/' },
      { '@type': 'ListItem', position: 2, name: 'About', item: site.url + '/about/' },
    ],
  },
];
---
<Base
  title="About Thryv — Chartered Accountants in Cape Town"
  description="Meet Thryv: chartered accountants in Cape Town & Stellenbosch on a mission to take accounting, tax and compliance off small business owners' plates so they can focus on growth."
  jsonLd={aboutLd}
>
  <PageHero
    eyebrow="About Thryv"
    title="Nurturing financial excellence for South African businesses"
    text="We exist so business owners can focus on what they do best — while we take care of the accounting, compliance and the numbers behind growth."
  />

  <section class="section">
    <div class="container two-col">
      <div>
        <span class="eyebrow">Our story</span>
        <h2>Built to take the stress off your plate</h2>
        <p>Thryv was founded to be a trusted accounting partner and a genuine business partner for companies that want to grow. Our founder, <strong>Arnaud Brunel</strong>, identified a gap in the industry: even with accountants, business owners were still pulled into the day-to-day of their company's finances.</p>
        <p>So he designed an offer and a set of processes that take away the entire workload and stress. Thryv does all the follow-ups, filings and reporting — freeing owners to focus entirely on their business.</p>
        <p>With a deep understanding of the local financial landscape and a commitment to excellence, we provide comprehensive financial services tailored to the unique needs of your business.</p>
      </div>
      <aside class="mission-card">
        <h3>Our mission</h3>
        <p>To create an environment in which business owners can let their business <em>thryv</em> — without any of the accounting and compliance hassles — while we provide the analytics and consultancy to help them grow.</p>
        <div class="loc">
          <span><Icon name="pin" /> {site.locations.join(' & ')}</span>
          <span><Icon name="mail" /> {site.email}</span>
          <span><Icon name="phone" /> {site.phoneDisplay}</span>
        </div>
      </aside>
    </div>
  </section>

  <section class="section section--soft">
    <div class="container">
      <div class="section-head center"><span class="eyebrow">What we stand for</span><h2>Our values</h2></div>
      <div class="grid grid-4">
        {values.map((v) => (
          <div class="card value">
            <div class="icon-chip"><Icon name={v.icon} /></div>
            <h3>{v.t}</h3>
            <p class="muted">{v.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head center"><span class="eyebrow">Leadership</span><h2>The people behind Thryv</h2></div>
      <div class="grid grid-2 team">
        {site.founders.map((f) => (
          <div class="card member">
            <div class="avatar">{f.name.split(' ').map((n) => n[0]).join('')}</div>
            <div>
              <h3>{f.name}</h3>
              <p class="muted">{f.role}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CtaBand />
</Base>

<style>
  .two-col { display: grid; grid-template-columns: 1.3fr 0.7fr; gap: 3rem; align-items: start; }
  .mission-card { background: var(--bg-mint); border-radius: var(--radius-lg); padding: 2rem; }
  .mission-card h3 { color: var(--teal-700); }
  .loc { display: grid; gap: 0.6rem; margin-top: 1.4rem; padding-top: 1.4rem; border-top: 1px solid var(--line-strong); font-size: 0.95rem; }
  .loc span { display: inline-flex; align-items: center; gap: 0.5rem; color: var(--ink-700); }
  .loc :global(svg) { width: 17px; height: 17px; color: var(--teal-600); }
  .value h3 { font-size: 1.12rem; }
  .team .member { display: flex; align-items: center; gap: 1.2rem; }
  .avatar { width: 64px; height: 64px; border-radius: 50%; background: var(--gradient-bright); color: #fff; display: grid; place-items: center; font-family: var(--font-head); font-weight: 800; font-size: 1.3rem; flex: none; }
  .member h3 { margin: 0; font-size: 1.2rem; }
  .member p { margin: 0.2rem 0 0; }
  @media (max-width: 820px) { .two-col { grid-template-columns: 1fr; } }
</style>
