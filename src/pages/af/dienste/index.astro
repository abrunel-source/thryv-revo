---
import Base from '../../../layouts/Base.astro';
import ServicesIndex from '../../../components/pages/ServicesIndex.astro';
import { routes } from '../../../i18n/config';
import { t } from '../../../i18n/ui';

const lang = 'af';
const meta = t(lang).meta;
const alternates = { en: routes('en').services, af: routes('af').services };
---
<Base lang={lang} alternates={alternates} title={meta.servicesTitle} description={meta.servicesDesc}>
  <ServicesIndex lang={lang} />
</Base>
