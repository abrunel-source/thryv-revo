---
import Base from '../../../layouts/Base.astro';
import BlogIndex from '../../../components/pages/BlogIndex.astro';
import { routes } from '../../../i18n/config';
import { t } from '../../../i18n/ui';

const lang = 'af';
const meta = t(lang).meta;
const alternates = { en: routes('en').blog, af: routes('af').blog };
---
<Base lang={lang} alternates={alternates} title={meta.blogTitle} description={meta.blogDesc}>
  <BlogIndex lang={lang} />
</Base>
