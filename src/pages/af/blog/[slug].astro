---
import Base from '../../../layouts/Base.astro';
import BlogPost from '../../../components/pages/BlogPost.astro';
import { site } from '../../../data/site';
import { getAllPosts, localizePost, categoryLabel } from '../../../lib/posts';
import { routes, blogHref } from '../../../i18n/config';

export function getStaticPaths() {
  return getAllPosts().map((p) => ({ params: { slug: p.af?.slug ?? p.slug }, props: { post: p } }));
}
const { post } = Astro.props;
const lang = 'af';
const lp = localizePost(post, lang);
const r = routes(lang);
const url = new URL(blogHref(lang, post.slug, post.af?.slug), site.url).href;
const alternates = { en: blogHref('en', post.slug), af: blogHref('af', post.slug, post.af?.slug) };

const jsonLd = [
  {
    '@context': 'https://schema.org', '@type': 'BlogPosting',
    headline: lp.title, description: lp.desc || lp.excerpt,
    datePublished: post.date, dateModified: post.modified || post.date, inLanguage: 'af-ZA',
    author: { '@type': 'Organization', name: site.legalName },
    publisher: { '@type': 'Organization', name: site.legalName, logo: { '@type': 'ImageObject', url: new URL(site.logo, site.url).href } },
    mainEntityOfPage: url, articleSection: categoryLabel(post.cats?.[0], lang),
  },
  {
    '@context': 'https://schema.org', '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Tuis', item: new URL(r.home, site.url).href },
      { '@type': 'ListItem', position: 2, name: 'Blog', item: new URL(r.blog, site.url).href },
      { '@type': 'ListItem', position: 3, name: lp.title, item: url },
    ],
  },
];
---
<Base lang={lang} alternates={alternates} title={lp.title} description={lp.desc || lp.excerpt} jsonLd={jsonLd}>
  <BlogPost post={post} lang={lang} />
</Base>
