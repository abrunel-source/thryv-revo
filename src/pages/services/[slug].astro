---
import Base from '../../layouts/Base.astro';
import CtaBand from '../../components/CtaBand.astro';
import Icon from '../../components/Icon.astro';
import { services, site } from '../../data/site';
import { serviceDetails } from '../../data/serviceDetails';
import serviceExtra from '../../data/serviceExtra.json';

export function getStaticPaths() {
  return services.map((s) => ({ params: { slug: s.slug }, props: { service: s } }));
}
const { service } = Astro.props;
const detail = serviceDetails[service.slug];
const extra = (serviceExtra as Record<string, { metaTitle: string; metaDescription: string; keyword: string; body: { heading: string; paragraphs: string[] }[]; faqs: { q: string; a: string }[] }>)[service.slug];
const others = services.filter((s) => s.slug !== service.slug).slice(0, 3);

const pageUrl = new URL(`/services/${service.slug}/`, site.url).href;
const metaTitle = extra?.metaTitle ?? `${service.title} — ${service.tagline}`;
const metaDescription = extra?.metaDescription ?? service.summary;

const serviceLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: service.title,
  serviceType: service.title,
  description: service.summary,
  provider: { '@type': 'AccountingService', name: site.legalName, url: site.url },
  areaServed: { '@type': 'Country', name: 'South Africa' },
  url: pageUrl,
};
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.url + '/' },
    { '@type': 'ListItem', position: 2, name: 'Services', item: site.url + '/services/' },
    { '@type': 'ListItem', position: 3, name: service.title, item: pageUrl },
  ],
};
const faqLd = extra?.faqs?.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: extra.faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    }
  : null;
const jsonLd = [serviceLd, breadcrumbLd, ...(faqLd ? [faqLd] : [])];
---
<Base fullTitle={metaTitle} description={metaDescription} jsonLd={jsonLd}>
  <section class="svc-hero">
    <div class="container">
      <nav class="crumbs" aria-label="Breadcrumb">
        <a href="/">Home</a> <span>/</span> <a href="/services/">Services</a> <span>/</span> <span aria-current="page">{service.title}</span>
      </nav>
      <div class="svc-hero-grid">
        <div>
          <span class="eyebrow">{service.tagline}</span>
          <h1>{service.title}</h1>
          <p class="lead">{detail?.intro ?? service.summary}</p>
          <div class="hero-cta">
            <a href="/contact/" class="btn btn--light">Get a quote <Icon name="arrow" class="ic" /></a>
            <a href={site.phoneHref} class="btn btn--on-dark">{site.phoneDisplay}</a>
          </div>
        </div>
        <div class="svc-icon"><Icon name={service.icon} /></div>
      </div>
    </div>
  </section>

  {detail && (
    <section class="section">
      <div class="container two-col">
        <div>
          <span class="eyebrow">What's included</span>
          <h2>Everything you need, handled</h2>
          <ul class="incl">
            {detail.included.map((i) => <li><Icon name="check" class="ftick" /> {i}</li>)}
          </ul>
        </div>
        <div class="outcomes">
          {detail.outcomes.map((o) => (
            <div class="card outcome">
              <div class="icon-chip"><Icon name="spark" /></div>
              <strong>{o.title}</strong>
              <p class="muted">{o.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {extra?.body?.length && (
    <section class="section section--soft">
      <div class="container narrow-body prose">
        {extra.body.map((b) => (
          <div class="body-block">
            <h2>{b.heading}</h2>
            {b.paragraphs.map((p) => <p set:html={p} />)}
          </div>
        ))}
      </div>
    </section>
  )}

  {extra?.faqs?.length && (
    <section class="section">
      <div class="container narrow-body">
        <div class="section-head"><span class="eyebrow">FAQs</span><h2>{service.title}: common questions</h2></div>
        <div class="faqs">
          {extra.faqs.map((f) => (
            <details class="faq">
              <summary>{f.q}</summary>
              <p>{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="section">
    <div class="container">
      <div class="section-head center"><span class="eyebrow">Explore more</span><h2>Other services</h2></div>
      <div class="grid grid-3">
        {others.map((s) => (
          <a href={`/services/${s.slug}/`} class="card service-card">
            <div class="icon-chip"><Icon name={s.icon} /></div>
            <h3>{s.title}</h3>
            <p class="muted">{s.summary}</p>
            <span class="learn">Learn more <Icon name="arrow" class="ic" /></span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CtaBand />
</Base>

<style>
  .svc-hero { background: var(--gradient); color: #fff; padding: clamp(2rem, 5vw, 3rem) 0 clamp(2.8rem, 6vw, 4rem); position: relative; overflow: hidden; }
  .crumbs { font-size: 0.85rem; color: #a9cfcd; margin-bottom: 1.4rem; display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .crumbs a { color: #cdeae8; }
  .crumbs span[aria-current] { color: #fff; }
  .svc-hero-grid { display: grid; grid-template-columns: 1.4fr 0.6fr; gap: 2rem; align-items: center; }
  .svc-hero .eyebrow { color: var(--teal-400); }
  .svc-hero h1 { color: #fff; }
  .svc-hero .lead { color: #cfe6e4; }
  .hero-cta { display: flex; gap: 0.8rem; flex-wrap: wrap; margin-top: 1.6rem; }
  .ic { width: 18px; height: 18px; }
  .svc-icon { justify-self: end; width: 130px; height: 130px; border-radius: 28px; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); display: grid; place-items: center; }
  .svc-icon :global(svg) { width: 60px; height: 60px; color: #fff; }

  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: start; }
  .incl { list-style: none; margin: 1.4rem 0 0; padding: 0; display: grid; gap: 0.9rem; }
  .incl li { display: flex; gap: 0.7rem; align-items: flex-start; font-size: 1.04rem; color: var(--ink-700); }
  .ftick { width: 20px; height: 20px; color: var(--teal-600); flex: none; margin-top: 3px; }
  .outcomes { display: grid; gap: 1rem; }
  .outcome strong { font-family: var(--font-head); color: var(--ink); display: block; margin-bottom: 0.2rem; }
  .outcome p { margin: 0; font-size: 0.95rem; }
  .service-card { display: flex; flex-direction: column; }
  .service-card h3 { color: var(--ink); }
  .service-card .muted { flex: 1; font-size: 0.95rem; }
  .learn { display: inline-flex; align-items: center; gap: 0.4rem; color: var(--teal-700); font-family: var(--font-head); font-weight: 600; font-size: 0.92rem; margin-top: 1rem; }

  .narrow-body { max-width: 820px; }
  .body-block { margin-bottom: 1.8rem; }
  .body-block:last-child { margin-bottom: 0; }
  .prose h2 { font-size: 1.5rem; margin-bottom: 0.8rem; }
  .prose p { font-size: 1.05rem; line-height: 1.75; color: var(--ink-700); margin: 0 0 1rem; }
  .prose :global(a) { color: var(--teal-700); text-decoration: underline; text-underline-offset: 2px; }
  .prose :global(a:hover) { color: var(--teal-600); }

  .faqs { display: grid; gap: 0.8rem; margin-top: 1.6rem; }
  .faq { border: 1px solid var(--line); border-radius: var(--radius); background: #fff; padding: 0.2rem 1.2rem; }
  .faq summary { font-family: var(--font-head); font-weight: 700; color: var(--ink); cursor: pointer; padding: 1rem 0; list-style: none; display: flex; justify-content: space-between; gap: 1rem; }
  .faq summary::-webkit-details-marker { display: none; }
  .faq summary::after { content: '+'; color: var(--teal-600); font-size: 1.3rem; line-height: 1; flex: none; }
  .faq[open] summary::after { content: '\2212'; }
  .faq p { margin: 0 0 1rem; color: var(--ink-700); line-height: 1.7; }

  @media (max-width: 820px) {
    .svc-hero-grid, .two-col { grid-template-columns: 1fr; }
    .svc-icon { display: none; }
  }
</style>
