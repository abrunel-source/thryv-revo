---
import Base from '../layouts/Base.astro';
import Icon from '../components/Icon.astro';
import { site } from '../data/site';

const contactLd = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Contact Thryv — Small Business Accountants in Cape Town',
  url: `${site.url}/contact/`,
};
---
<Base
  title="Contact a Small Business Accountant — Free Call"
  description="Talk to a small business accountant in Cape Town. Book a free, no-obligation call or request a fixed-fee quote for accounting, tax, bookkeeping and payroll in South Africa."
  jsonLd={contactLd}
>
  <section class="contact-hero">
    <div class="container grid-wrap">
      <div class="intro">
        <span class="eyebrow">Get in touch</span>
        <h1>Talk to a small business accountant</h1>
        <p class="lead">Book a free, no-obligation call with a Cape Town chartered accountant. We'll show you exactly how a fixed-fee accounting partner can save you time, cut your tax bill and take SARS and CIPC compliance off your plate.</p>

        <ul class="contact-list">
          <li><span class="ci"><Icon name="phone" /></span><div><strong>Call us</strong><a href={site.phoneHref}>{site.phoneDisplay}</a></div></li>
          <li><span class="ci"><Icon name="mail" /></span><div><strong>Email</strong><a href={`mailto:${site.email}`}>{site.email}</a></div></li>
          <li><span class="ci"><Icon name="pin" /></span><div><strong>Offices</strong><span>{site.locations.join(' & ')}, South Africa</span></div></li>
          <li><span class="ci"><Icon name="clock" /></span><div><strong>Hours</strong><span>Mon–Fri, 08:00–17:00 SAST</span></div></li>
        </ul>

        <div class="socials">
          <a href={site.social.facebook} aria-label="Thryv on Facebook" rel="noopener" target="_blank"><Icon name="facebook" /></a>
          <a href={site.social.linkedin} aria-label="Thryv on LinkedIn" rel="noopener" target="_blank"><Icon name="linkedin" /></a>
          <a href={site.social.twitter} aria-label="Thryv on Twitter" rel="noopener" target="_blank"><Icon name="twitter" /></a>
        </div>
      </div>

      <div class="form-card card">
        <h2>Request a quote</h2>
        <p class="muted">Tell us a little about your business and we'll be in touch within one business day.</p>
        <div class="form-status" id="form-status" role="status" hidden></div>
        <form action="/api/contact" method="POST" class="form" id="contact-form">
          <!-- Honeypot: hidden from humans; bots that fill it are silently dropped. -->
          <div class="hp" aria-hidden="true">
            <label>Company website<input type="text" name="company_website" tabindex="-1" autocomplete="off" /></label>
          </div>
          <input type="hidden" name="form_ts" id="form-ts" value="" />
          <div class="row">
            <label>Full name<input type="text" name="name" autocomplete="name" required placeholder="Your name" /></label>
            <label>Company<input type="text" name="company" autocomplete="organization" placeholder="Company name" /></label>
          </div>
          <div class="row">
            <label>Email<input type="email" name="email" autocomplete="email" required placeholder="you@company.co.za" /></label>
            <label>Phone<input type="tel" name="phone" autocomplete="tel" placeholder="+27 …" /></label>
          </div>
          <label>Which service are you interested in?
            <select name="service">
              <option>Monthly accounting package</option>
              <option>Bookkeeping</option>
              <option>Tax &amp; SARS</option>
              <option>Payroll</option>
              <option>Audit / Independent review</option>
              <option>Employer of Record</option>
              <option>Something else</option>
            </select>
          </label>
          <label>Message<textarea name="message" rows="4" placeholder="Tell us about your business…"></textarea></label>
          <button type="submit" class="btn btn--primary submit">Send my request <Icon name="arrow" class="ic" /></button>
          <p class="form-note">By submitting you agree to our <a href="/privacy/">privacy policy</a>.</p>
        </form>
      </div>
    </div>
  </section>

  <script is:inline>
    (function () {
      var form = document.getElementById('contact-form');
      var status = document.getElementById('form-status');
      var ts = document.getElementById('form-ts');
      if (ts) ts.value = String(Date.now());

      function show(kind, msg) {
        if (!status) return;
        status.hidden = false;
        status.className = 'form-status ' + (kind === 'ok' ? 'is-ok' : 'is-err');
        status.textContent = msg;
      }

      // No-JS fallback: the server redirects to ?sent=1 / ?error=1 after POST.
      var params = new URLSearchParams(location.search);
      if (params.get('sent') === '1') show('ok', 'Thanks — your message is on its way. We’ll be in touch within one business day.');
      else if (params.get('error') === '1') show('err', 'Sorry, something went wrong. Please try again or email admin@thryv.co.za.');

      if (!form) return;
      form.addEventListener('submit', function (e) {
        e.preventDefault();
        var btn = form.querySelector('button[type=submit]');
        if (btn) { btn.disabled = true; btn.dataset.label = btn.innerHTML; btn.textContent = 'Sending…'; }
        var body = new URLSearchParams(new FormData(form));
        fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'fetch', Accept: 'application/json' },
          body: body,
        })
          .then(function (r) { return r.json().catch(function () { return { ok: r.ok }; }); })
          .then(function (d) {
            if (d && d.ok) {
              form.reset();
              if (ts) ts.value = String(Date.now());
              show('ok', 'Thanks — your message is on its way. We’ll be in touch within one business day.');
            } else {
              show('err', (d && d.error) || 'Sorry, something went wrong. Please try again or email admin@thryv.co.za.');
            }
          })
          .catch(function () {
            show('err', 'Network error. Please try again or email admin@thryv.co.za.');
          })
          .finally(function () {
            if (btn) { btn.disabled = false; btn.innerHTML = btn.dataset.label || 'Send my request'; }
          });
      });
    })();
  </script>
</Base>

<style>
  .contact-hero { padding: clamp(2.5rem, 6vw, 4rem) 0; background: var(--bg-soft); }
  .grid-wrap { display: grid; grid-template-columns: 1fr 1.05fr; gap: 3rem; align-items: start; }
  .contact-list { list-style: none; margin: 2rem 0; padding: 0; display: grid; gap: 1.1rem; }
  .contact-list li { display: flex; gap: 1rem; align-items: center; }
  .ci { width: 46px; height: 46px; border-radius: 12px; background: var(--bg-mint); color: var(--teal-700); display: grid; place-items: center; flex: none; }
  .ci :global(svg) { width: 20px; height: 20px; }
  .contact-list strong { display: block; font-family: var(--font-head); color: var(--ink); font-size: 0.9rem; }
  .contact-list a, .contact-list span { color: var(--ink-700); }
  .socials { display: flex; gap: 0.6rem; }
  .socials a { width: 42px; height: 42px; border-radius: 11px; display: grid; place-items: center; background: #fff; border: 1px solid var(--line); color: var(--teal-700); }
  .socials a:hover { background: var(--teal-600); color: #fff; }
  .socials :global(svg) { width: 19px; height: 19px; }

  .form-card { box-shadow: var(--shadow-lg); }
  .form-card h2 { font-size: 1.5rem; margin-bottom: 0.3rem; }
  .form { display: grid; gap: 1rem; margin-top: 1.4rem; }
  .row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  label { font-family: var(--font-head); font-weight: 600; font-size: 0.88rem; color: var(--ink); display: grid; gap: 0.4rem; }
  input, select, textarea {
    font-family: var(--font-body); font-size: 1rem; font-weight: 400; color: var(--ink-700);
    padding: 0.7rem 0.85rem; border: 1.5px solid var(--line-strong); border-radius: 10px; background: #fff; width: 100%;
  }
  input:focus, select:focus, textarea:focus { outline: none; border-color: var(--teal-500); box-shadow: 0 0 0 3px rgba(16,156,146,0.15); }
  textarea { resize: vertical; }
  .submit { justify-content: center; margin-top: 0.4rem; }
  .ic { width: 18px; height: 18px; }
  .form-note { font-size: 0.82rem; color: var(--slate); margin: 0; font-weight: 400; font-family: var(--font-body); }
  /* Honeypot — visually & semantically hidden, but still in the DOM for bots. */
  .hp { position: absolute; left: -9999px; width: 1px; height: 1px; overflow: hidden; }
  .form-status { border-radius: 10px; padding: 0.85rem 1rem; margin-top: 1rem; font-size: 0.92rem; font-family: var(--font-head); font-weight: 600; }
  .form-status.is-ok { background: var(--bg-mint); color: var(--teal-700); border: 1px solid var(--teal-500); }
  .form-status.is-err { background: #fdecea; color: #a8331f; border: 1px solid #f0b4aa; }
  @media (max-width: 860px) { .grid-wrap { grid-template-columns: 1fr; } }
  @media (max-width: 480px) { .row { grid-template-columns: 1fr; } }
</style>
